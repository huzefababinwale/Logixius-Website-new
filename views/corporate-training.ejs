<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Corporate Training - Logixius AI</title>
    <meta name="description"
        content="Professional corporate training programs in AI, Machine Learning, and Robotics for modern businesses and enterprises.">
    <link rel="stylesheet" href="/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="icon" href="/assets/Logo/logo_logixius1.png" type="image/png">
</head>

<body>

    <%- include('partials/header') %>

        <!-- Hero Section -->
        <section class="hero workshops-hero">
            <div class="container text-center">
                <span class="badge">Professional Development</span>
                <h1 class="hero-title">Corporate <br><span class="gradient-text">Training Programs</span></h1>
                <p class="section-desc hero-desc">
                    Empower your workforce with advanced, customized corporate training programs. We specialize in
                    equipping
                    corporate teams and enterprises with cutting-edge skills in Artificial Intelligence, Machine
                    Learning,
                    Data Science, and Automation to drive innovation and productivity.
                </p>
            </div>
        </section>

        <!-- Services Grid Section -->
        <section class="workshops-section">
            <div class="container">
                <div class="section-header text-center" style="margin-bottom: 3rem;">
                    <h2>Our Training Solutions</h2>
                    <p>Comprehensive learning paths designed specifically for industry professionals.</p>
                </div>

                <div class="workshops-grid">

                    <!-- AI for Executives -->
                    <div class="workshop-card">
                        <div class="workshop-img"
                            style="height: 250px; overflow: hidden; background: #e2e8f0; display: flex; align-items: center; justify-content: center;">
                            <img src="/assets/portfolio/image24.jpg" alt="AI for Business Leaders"
                                style="width: 100%; height: 100%; object-fit: cover;">
                        </div>
                        <div class="workshop-content">
                            <div class="card-icon blue">
                                <i class="fas fa-user-tie"></i>
                            </div>
                            <h3>AI for Business Leaders</h3>
                            <p>
                                Strategic workshops designed for executives and managers to understand the business
                                implications
                                of AI, identify high ROI use cases, and lead successful AI transformations within their
                                organizations.
                            </p>
                            <a href="/#contact" class="read-more">Request Details <i class="fas fa-arrow-right"></i></a>
                        </div>
                    </div>

                    <!-- Technical Upskilling -->
                    <div class="workshop-card">
                        <div class="workshop-img"
                            style="height: 250px; overflow: hidden; background: #e2e8f0; display: flex; align-items: center; justify-content: center;">
                            <img src="/assets/portfolio/image25.jpg" alt="Technical Upskilling Workshops"
                                style="width: 100%; height: 100%; object-fit: cover;">
                        </div>
                        <div class="workshop-content">
                            <div class="card-icon purple">
                                <i class="fas fa-laptop-code"></i>
                            </div>
                            <h3>Deep-Tech Upskilling</h3>
                            <p>
                                Intensive, hands-on training for software engineering and IT teams. We cover practical
                                implementation
                                of Machine Learning models, Deep Learning architectures, and scalable AI deployment
                                using modern frameworks.
                            </p>
                            <a href="/#contact" class="read-more">View Modules <i class="fas fa-arrow-right"></i></a>
                        </div>
                    </div>

                    <!-- Automation & Data Analytics -->
                    <div class="workshop-card">
                        <div class="workshop-img"
                            style="height: 250px; overflow: hidden; background: #e2e8f0; display: flex; align-items: center; justify-content: center;">
                            <img src="/assets/portfolio/image20.jpg" alt="Data Analytics and Automation"
                                style="width: 100%; height: 100%; object-fit: cover;">
                        </div>
                        <div class="workshop-content">
                            <div class="card-icon pink">
                                <i class="fas fa-chart-line"></i>
                            </div>
                            <h3>Data Analytics & Automation</h3>
                            <p>
                                Equip your analysts and operations teams with the skills to leverage data for actionable
                                insights
                                and integrate intelligent automation tools to streamline day-to-day business processes
                                effectively.
                            </p>
                            <a href="/#contact" class="read-more">Connect With Us <i class="fas fa-arrow-right"></i></a>
                        </div>
                    </div>

                </div>
            </div>
        </section>

        <!-- CTA Section for Training -->
        <section class="cta-section"
            style="padding: 5rem 0; background-color: #f1f5f9; text-align: center; margin-bottom: 2rem;">
            <div class="container">
                <h2 style="font-size: 2.5rem; margin-bottom: 1rem; color: #1e293b;">Need a Customized Training Plan?
                </h2>
                <p
                    style="font-size: 1.1rem; color: #64748b; margin-bottom: 2rem; max-width: 600px; margin-left: auto; margin-right: auto;">
                    We can tailor our curriculum to match your company's specific tech stack, industry challenges, and
                    strategic goals.
                </p>
                <a href="/#contact" class="btn" style="padding: 1rem 2rem; font-weight: 600; border-radius: 8px;">Talk
                    to our Experts</a>
            </div>
        </section>

        <%- include('partials/footer') %>

            <script src="/script.js"></script>
</body>

</html>