                                                    <%= new Date(cert.issue_date).toLocaleDateString() %>
                                                </td>
                                                <td style="padding: 1rem;">
                                                    <a href="<%= cert.certificate_file_path %>" target="_blank"
                                                        style="color: #2563EB; text-decoration: none; margin-right: 10px;">View
                                                        Certificate</a>
                                                </td>
                                            </tr>
                                            <% }); %>
                                                <% } else { %>
                                                    <tr>
                                                        <td colspan="5"
                                                            style="padding: 2rem; text-align: center; color: #64748b;">
                                                            No completed internships yet.</td>
                                                    </tr>
                                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Intern Details Section (Full Info) -->
                    <div id="details-section" style="display: none;">
                        <h4 class="mb-3">All Registered Interns</h4>
                        <div style="overflow-x: auto;">
                            <table style="width: 100%; border-collapse: collapse; min-width: 900px;">
                                <thead>
                                    <tr style="background: #f1f5f9; text-align: left;">
                                        <th style="padding: 1rem; border-bottom: 2px solid #e2e8f0;">Personal Profile
                                        </th>
                                        <th style="padding: 1rem; border-bottom: 2px solid #e2e8f0;">Education</th>
                                        <th style="padding: 1rem; border-bottom: 2px solid #e2e8f0;">Internship Status
                                        </th>
                                        <th style="padding: 1rem; border-bottom: 2px solid #e2e8f0;">Dates</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (locals.allStudents && allStudents.length> 0) { %>
                                        <% allStudents.forEach(stu=> { %>
                                            <tr style="border-bottom: 1px solid #e2e8f0;">
                                                <td style="padding: 1rem;">
                                                    <strong>
                                                        <%= stu.full_name %>
                                                    </strong> <span style="font-size: 0.8rem; color: #64748b;">(<%=
                                                            stu.gender %>)</span><br>
                                                    <div style="margin-top: 5px; font-size: 0.85rem;">
                                                        <i class="fas fa-envelope"
                                                            style="width: 16px; color: #64748b;"></i>
                                                        <%= stu.email %><br>
                                                            <i class="fas fa-phone"
                                                                style="width: 16px; color: #64748b;"></i>
                                                            <%= stu.mobile_no %>
                                                    </div>
                                                </td>
                                                <td style="padding: 1rem;">
                                                    <strong>
                                                        <%= stu.degree %>
                                                    </strong><br>
                                                    <span style="color: #1e293b;">
                                                        <%= stu.department %>
                                                    </span><br>
                                                    <span style="font-size: 0.9rem; color: #64748b;">
                                                        <%= stu.college_name %>
                                                    </span>
                                                </td>
                                                <td style="padding: 1rem;">
                                                    <% if (stu.application_status==='PENDING' ) { %>
                                                        <span
                                                            style="background: #fff7ed; color: #9a3412; padding: 0.2rem 0.5rem; border-radius: 4px; font-size: 0.85rem;">Pending</span>
                                                        <br><small>
                                                            <%= stu.domain %>
                                                        </small>
                                                        <% } else if (stu.application_status==='ONGOING' ) { %>
                                                            <span
                                                                style="background: #e0f2fe; color: #0369a1; padding: 0.2rem 0.5rem; border-radius: 4px; font-size: 0.85rem;">Ongoing</span>
                                                            <br><small><strong>
                                                                    <%= stu.domain %>
                                                                </strong></small><br>
                                                            <small style="color: #64748b;">ID: <%= stu.intern_id %>
                                                            </small>
                                                            <% } else if (stu.application_status==='COMPLETED' ) { %>
                                                                <span
                                                                    style="background: #dcfce7; color: #166534; padding: 0.2rem 0.5rem; border-radius: 4px; font-size: 0.85rem;">Completed</span>
                                                                <br><small><strong>
                                                                        <%= stu.domain %>
                                                                    </strong></small><br>
                                                                <small style="color: #64748b;">ID: <%= stu.intern_id %>
                                                                </small>
                                                                <% } else { %>
                                                                    <span
                                                                        style="background: #f1f5f9; color: #64748b; padding: 0.2rem 0.5rem; border-radius: 4px; font-size: 0.85rem;">
                                                                        <%= stu.application_status %>
                                                                    </span>
                                                                    <% } %>
                                                </td>
                                                <td style="padding: 1rem; font-size: 0.9rem;">
                                                    <% if (stu.start_date) { %>
                                                        <div style="margin-bottom: 4px;"><strong>Start:</strong>
                                                            <%= new Date(stu.start_date).toLocaleDateString() %>
                                                        </div>
                                                        <% } %>
                                                            <% if (stu.completion_date) { %>
                                                                <div style="color: #166534;"><strong>End:</strong>
                                                                    <%= new
                                                                        Date(stu.completion_date).toLocaleDateString()
                                                                        %>
                                                                </div>
                                                                <% } %>
                                                                    <div
                                                                        style="color: #94a3b8; font-size: 0.8rem; margin-top: 4px;">
                                                                        Joined: <%= new
                                                                            Date(stu.created_at).toLocaleDateString() %>
                                                                    </div>
                                                </td>
                                            </tr>
                                            <% }); %>
                                                <% } else { %>
                                                    <tr>
                                                        <td colspan="4"
                                                            style="padding: 2rem; text-align: center; color: #64748b;">
                                                            No registered students found.</td>
                                                    </tr>
                                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>

        </section>

        <script>
            function switchTab(tab) {
                const appSection = document.getElementById('applications-section');
                const ongoingSection = document.getElementById('ongoing-section');
                const completedSection = document.getElementById('completed-section');
                const detailsSection = document.getElementById('details-section');
                const tabs = document.querySelectorAll('.nav-tab');

                // Reset all
                appSection.style.display = 'none';
                ongoingSection.style.display = 'none';
                completedSection.style.display = 'none';
                detailsSection.style.display = 'none';
                tabs.forEach(t => t.classList.remove('active'));

                if (tab === 'applications') {
                    appSection.style.display = 'block';
                    tabs[0].classList.add('active');
                } else if (tab === 'ongoing') {
                    ongoingSection.style.display = 'block';
                    tabs[1].classList.add('active');
                } else if (tab === 'completed') {
                    completedSection.style.display = 'block';
                    tabs[2].classList.add('active');
                } else {
                    detailsSection.style.display = 'block';
                    tabs[3].classList.add('active');
                }
            }
        </script>
</body>

<!-- Student Details Modal -->
<div id="studentModal"
    style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center;">
    <div
        style="background: white; width: 90%; max-width: 500px; padding: 2rem; border-radius: 12px; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1); position: relative;">
        <button onclick="closeStudentModal()"
            style="position: absolute; top: 1rem; right: 1rem; background: none; border: none; font-size: 1.5rem; cursor: pointer; color: #64748b;">&times;</button>

        <h3 style="margin-bottom: 1.5rem; border-bottom: 2px solid #e2e8f0; padding-bottom: 0.5rem;">Intern Application
            Details</h3>

        <div style="display: flex; flex-direction: column; gap: 1rem;">
            <div>
                <label
                    style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b; font-weight: 600;">Full
                    Name</label>
                <div id="modal-name" style="font-weight: 500; font-size: 1.1rem;"></div>
            </div>

            <div style="display: flex; gap: 1rem;">
                <div style="flex: 1;">
                    <label
                        style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b; font-weight: 600;">Email</label>
                    <div id="modal-email"></div>
                </div>
                <div style="flex: 1;">
                    <label
                        style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b; font-weight: 600;">Phone</label>
                    <div id="modal-phone"></div>
                </div>
            </div>

            <div style="display: flex; gap: 1rem;">
                <div style="flex: 1;">
                    <label
                        style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b; font-weight: 600;">Gender</label>
                    <div id="modal-gender"></div>
                </div>
                <div style="flex: 1;">
                    <label
                        style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b; font-weight: 600;">Applied
                        On</label>
                    <div id="modal-date"></div>
                </div>
            </div>

            <div>
                <label
                    style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b; font-weight: 600;">College</label>
                <div id="modal-college"></div>
            </div>

            <div style="display: flex; gap: 1rem;">
                <div style="flex: 1;">
                    <label
                        style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b; font-weight: 600;">Degree</label>
                    <div id="modal-degree"></div>
                </div>
                <div style="flex: 1;">
                    <label
                        style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b; font-weight: 600;">Department</label>
                    <div id="modal-dept"></div>
                </div>
            </div>

            <div>
                <label
                    style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b; font-weight: 600;">Applied
                    Domain</label>
                <div id="modal-domain"
                    style="display: inline-block; background: #dcfce7; color: #166534; padding: 2px 8px; border-radius: 4px; font-weight: 500; font-size: 0.9rem;">
                </div>
            </div>
        </div>

        <div style="margin-top: 2rem; display: flex; justify-content: flex-end;">
            <button onclick="closeStudentModal()" class="btn-primary"
                style="background: #64748b; border: none;">Close</button>
        </div>
    </div>
</div>

<script>
    function openStudentModal(name, email, phone, gender, college, degree, dept, domain, date) {
        document.getElementById('modal-name').innerText = name;
        document.getElementById('modal-email').innerText = email;
        document.getElementById('modal-phone').innerText = phone;
        document.getElementById('modal-gender').innerText = gender;
        document.getElementById('modal-college').innerText = college;
        document.getElementById('modal-degree').innerText = degree;
        document.getElementById('modal-dept').innerText = dept;
        document.getElementById('modal-domain').innerText = domain;
        document.getElementById('modal-date').innerText = date;

        document.getElementById('studentModal').style.display = 'flex';
    }

    function closeStudentModal() {
        document.getElementById('studentModal').style.display = 'none';
    }
</script>

</html>