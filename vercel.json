{
    "version": 2,
    "builds": [
        {
            "src": "server.js",
            "use": "@vercel/node",
            "config": {
                "includeFiles": [
                    "assets/**",
                    "views/**",
                    "style.css",
                    "script.js"
                ]
            }
        }
    ],
    "rewrites": [
        {
            "source": "/assets/(.*)",
            "destination": "/assets/$1"
        },
        {
            "source": "/style.css",
            "destination": "/style.css"
        },
        {
            "source": "/script.js",
            "destination": "/script.js"
        },
        {
            "source": "/(.*)",
            "destination": "/server.js"
        }
    ]
}